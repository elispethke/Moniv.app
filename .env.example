# Copy this file to .env and fill in your values
# Get Supabase keys from: https://supabase.com/dashboard → Project Settings → API
# Get Stripe keys from: https://dashboard.stripe.com/apikeys

# ── Supabase (frontend) ──────────────────────────────────────────────────────
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your_publishable_anon_key_here

# ── Stripe (frontend — publishable key only) ─────────────────────────────────
# Used if Stripe.js is loaded directly on the frontend.
# The secret key MUST NEVER go here — set it as a Supabase secret (see below).
VITE_STRIPE_PUBLIC_KEY=pk_test_...

# ── Supabase Edge Function secrets ───────────────────────────────────────────
# Set these via: supabase secrets set KEY=value  (never commit real values)
#
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_PRICE_ID=price_...        ← create a €10/month recurring price in Stripe dashboard
# STRIPE_WEBHOOK_SECRET=whsec_...  ← from Stripe dashboard → Webhooks → your endpoint
# APP_URL=https://your-app-domain.com
